class Solution {
    public int aggressiveCows(int[] nums, int k) {
        Arrays.sort(nums);
        int low = 1, high = nums[nums.length - 1] - nums[0];
        int ans = 0;
        
        while (low <= high) {
            int mid = low + (high - low) / 2;
            if (canPlaceCows(nums, k, mid)) {
                ans = mid;
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }
        return ans;
    }

    private boolean canPlaceCows(int[] nums, int k, int minDistance) {
        int count = 1;
        int lastPosition = nums[0];
        
        for (int i = 1; i < nums.length; i++) {
            if (nums[i] - lastPosition >= minDistance) {
                count++;
                lastPosition = nums[i];
            }
        }
        return count >= k;
    }
}
