class Solution {
    public int findPages(int[] nums, int m) {
        if (m > nums.length) return -1;

        int low = 0, high = 0;
        for (int pages : nums) {
            low = Math.max(low, pages);
            high += pages;
        }

        int result = -1;
        while (low <= high) {
            int mid = low + (high - low) / 2;
            if (isPossible(nums, m, mid)) {
                result = mid;
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }
        return result;
    }

    private boolean isPossible(int[] nums, int m, int maxPages) {
        int students = 1;
        int currentPages = 0;
        for (int pages : nums) {
            currentPages += pages;
            if (currentPages > maxPages) {
                students++;
                currentPages = pages;
            }
        }
        return students <= m;
    }
}
