class ArrayStack {
    private int[] arr;
    private int top;

    public ArrayStack() {
        arr = new int[1000];
        top = -1;
    }

    public void push(int x) {
        top++;
        arr[top] = x;
    }

    public int pop() {
        if (top == -1) return -1;
        int x = arr[top];
        top--;
        return x;
    }

    public int top() {
        if (top == -1) return -1;
        return arr[top];
    }

    public boolean isEmpty() {
        return top == -1;
    }
}
