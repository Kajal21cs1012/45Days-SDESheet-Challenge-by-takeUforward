/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int data;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode(int val) { data = val; left = null, right = null }
 * }
 **/

class Solution {
    public List<Integer> succPredBST(TreeNode root, int key) {
        int successor = -1;
        int predecessor = -1;
        
        TreeNode curr = root;
        while (curr != null) {
            if (curr.data > key) {
                successor = curr.data;
                curr = curr.left;
            } else {
                curr = curr.right;
            }
        }
        
        curr = root;
        while (curr != null) {
            if (curr.data < key) {
                predecessor = curr.data;
                curr = curr.right;
            } else {
                curr = curr.left;
            }
        }
        
        List<Integer> result = new ArrayList<>();
        result.add(predecessor);
        result.add(successor);
        return result;
    }
}
