/*Definition of singly linked list:
class ListNode {
    int val;
    ListNode next;
    ListNode random;

    ListNode() {
        val = 0;
        next = null;
        random = null;
    }

    ListNode(int val) {
        this.val = val;
        next = null;
        random = null;
    }

    ListNode(int val, ListNode next, ListNode random) {
        this.val = val;
        this.next = next;
        this.random = random;
    }
}
 */

class Solution {
    public ListNode copyRandomList(ListNode head) {
        if (head == null) return null;
        
        java.util.Map<ListNode, ListNode> map = new java.util.HashMap<>();
        
        ListNode curr = head;
        while (curr != null) {
            map.put(curr, new ListNode(curr.val));
            curr = curr.next;
        }
        
        curr = head;
        while (curr != null) {
            ListNode copy = map.get(curr);
            copy.next = map.get(curr.next);
            copy.random = map.get(curr.random);
            curr = curr.next;
        }
        
        return map.get(head);
    }
}
