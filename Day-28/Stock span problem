class Solution {
    public int[] stockSpan(int[] arr, int n) {
        int[] spans = new int[n];
        Stack<int[]> stack = new Stack<>();
        
        for (int i = 0; i < n; i++) {
            int span = 1;
            while (!stack.isEmpty() && stack.peek()[0] <= arr[i]) {
                span += stack.pop()[1];
            }
            stack.push(new int[]{arr[i], span});
            spans[i] = span;
        }
        
        return spans;
    }
}
