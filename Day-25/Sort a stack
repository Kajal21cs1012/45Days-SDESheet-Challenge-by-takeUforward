class Solution {
    public void sortStack(Stack<Integer> st) {
        if (!st.isEmpty()) {
            int temp = st.pop();
            sortStack(st);
            insert(st, temp);
        }
    }

    private void insert(Stack<Integer> st, int val) {
        if (st.isEmpty() || st.peek() <= val) {
            st.push(val);
        } else {
            int temp = st.pop();
            insert(st, val);
            st.push(temp);
        }
    }
}
